# ─────────────────────────────────────────────────────────────────────
# Firebase — these env vars OVERRIDE the default in `src/config/brand.config.ts`.
# Use this for production deployments so the apiKey isn't committed to git.
#
# Copy this file to `.env.local` (git-ignored) and fill in your values.
# ─────────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Web Push (FCM) — من Firebase Console → Project settings → Cloud Messaging → Web Push certificates
# الصق مفتاح الزوج (VAPID) ليتمكن المتصفح من تسجيل token الإشعارات
VITE_FIREBASE_VAPID_KEY=
